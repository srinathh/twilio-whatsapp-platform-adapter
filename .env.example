# ── Required ──
# Shared with Hermes' built-in SMS adapter (same Twilio account).
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=CHANGE_ME
# E.164 WhatsApp sender. +14155238886 is Twilio's public sandbox number.
TWILIO_WHATSAPP_NUMBER=+14155238886
# Public URL Twilio POSTs to — required for signature validation.
TWILIO_WHATSAPP_WEBHOOK_URL=https://hermes.example.com/webhooks/twilio-whatsapp

# ── Optional ──
# Comma-separated E.164 numbers allowed to message the agent.
TWILIO_WHATSAPP_ALLOWED_USERS=+6500000000,+6500000001
#TWILIO_WHATSAPP_ALLOW_ALL_USERS=false
# Webhook bind (defaults shown). 0.0.0.0 so a tunnel/ingress can reach it.
#TWILIO_WHATSAPP_WEBHOOK_HOST=0.0.0.0
#TWILIO_WHATSAPP_WEBHOOK_PORT=8080
# E.164 number for cron/home-channel delivery.
#TWILIO_WHATSAPP_HOME_CHANNEL=+6500000000
# Dev only — disables Twilio signature validation.
#TWILIO_WHATSAPP_INSECURE_NO_SIGNATURE=false
# Override the outbound media staging dir.
#TWILIO_WHATSAPP_OUTBOUND_MEDIA_DIR=/opt/data/cache/twilio_whatsapp_outbound

# NOTE: do NOT set TWILIO_PHONE_NUMBER in a deployment using this plugin —
# it would satisfy the built-in SMS adapter's enablement check too.
